# ─────────────────────────────────────────────────────────────────────────────
#  .env de PRODUCCIÓN para FilamentOS
#
#  En el VPS este archivo vive en:  /opt/filamentos/backend/.env
#  NUNCA se commitea al repo. Ya está en .gitignore vía **/.env*
#
#  Antes de pegar en el VPS, cambia TODOS los valores marcados como "CAMBIAR".
# ─────────────────────────────────────────────────────────────────────────────

# Puerto interno del Express dentro del contenedor.
# No lo cambies a menos que también cambies el Dockerfile y el compose.
PORT=3001

# Dominio de tu web (el que apuntarás al VPS).
# Ojo: CORS compara esto contra el header Origin → tiene que ser EXACTO, con https.
CLIENT_ORIGIN=https://CAMBIAR.tudominio.com

# Ruta de la base de datos DENTRO del contenedor.
# Coincide con el volumen sqlite_data montado en /data en docker-compose.prod.yml.
DB_PATH=/data/data.db

# Secreto de sesión. GENERA UNO NUEVO para producción con:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# No reutilices el del Synology — rota secretos al cambiar de entorno.
SESSION_SECRET=CAMBIAR_genera_uno_nuevo_con_node_crypto

# Google OAuth — recuerda añadir el NUEVO callback en Google Cloud Console:
#   https://CAMBIAR.tudominio.com/auth/google/callback
GOOGLE_CLIENT_ID=CAMBIAR.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=CAMBIAR

# Gemini API Key
GOOGLE_GENAI_API_KEY=CAMBIAR

# Entorno
NODE_ENV=production

# Puppeteer dentro del contenedor Alpine
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser

# SMTP para el reporte de bugs
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=CAMBIAR@gmail.com
SMTP_PASS=CAMBIAR_contrasena_de_aplicacion_16_chars
BUG_REPORT_EMAIL=CAMBIAR@tudominio.com
